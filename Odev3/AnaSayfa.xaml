<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Odev3.AnaSayfa"
             Title="Ana Sayfa">

    <ScrollView>
        <VerticalStackLayout Spacing="30" Padding="20" VerticalOptions="Center">

            <Border StrokeThickness="0" HorizontalOptions="Center" WidthRequest="192" HeightRequest="280" StrokeShape="RoundRectangle 40">
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.5" Offset="0,10" Radius="20"/>
                </Border.Shadow>
                <Image x:Name="Profil" Source="user.png" Aspect="AspectFill"/>
            </Border>

            <Border StrokeShape="RoundRectangle 20" StrokeThickness="0" WidthRequest="1000" BackgroundColor="#5FBB9C">

                <VerticalStackLayout VerticalOptions="Center" 
                                     HorizontalOptions="Center" 
                                     Spacing="10"
                                     Padding="20">

                    <Label x:Name="AdSoyadLabel" Text="" FontSize="30" HorizontalOptions="Center" FontAttributes="Bold" TextColor="{AppThemeBinding Light=White, Dark=Black}" />

                    <Label Text="Bartın Üniversitesi Bilgisayar Mühendisliği" FontSize="14" HorizontalOptions="Center" HorizontalTextAlignment="Center" TextColor="{AppThemeBinding Light=White, Dark=Black}" />
                    <Label Text="Görsel Programlama Dersi Final Ödevi" FontSize="14" HorizontalOptions="Center" HorizontalTextAlignment="Center" TextColor="{AppThemeBinding Light=White, Dark=Black}" />

                    <Label x:Name="NumaraLabel" Text="" FontSize="30" HorizontalOptions="Center" TextColor="{AppThemeBinding Light=White, Dark=Black}" />

                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>