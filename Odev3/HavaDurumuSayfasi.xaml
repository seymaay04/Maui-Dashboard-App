<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Odev3.HavaDurumuSayfasi"
             Title="Hava Durumu">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Ekle" IconImageSource="ekle_ikon.png" Clicked="Ekle_clk"/>
        <ToolbarItem Text="Yenile" IconImageSource="yenile_ikon.png" Clicked="Yenile_clk"/>
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto, *">
        <CollectionView x:Name="HavaDurumuListesi" Grid.Row="1" Margin="5">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,5,0,10" Padding="10" CornerRadius="15" BackgroundColor="{AppThemeBinding Light=White, Dark=Black}" BorderColor="#E0E0E0" HasShadow="True">
                        <StackLayout Spacing="5">

                            <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,5">
                                <Label Text="{Binding Isim}" FontSize="22" FontAttributes="Bold" TextColor="#333" VerticalOptions="Center"/>

                                <Button Grid.Column="1" Text="Sil" Clicked="Sil_clk" CommandParameter="{Binding .}" 
                                        BackgroundColor="#5FBB9C" TextColor="White" 
                                        HeightRequest="35" CornerRadius="5" FontSize="12"/>
                            </Grid>

                            <Grid ColumnDefinitions="1*, 2.5*" ColumnSpacing="5">

                                <StackLayout Grid.Column="0">
                                    <Label Text="Bugün" FontSize="12" FontAttributes="Bold" TextColor="Gray" HorizontalOptions="Center" Margin="0,0,0,5"/>
                                    <WebView Source="{Binding BugunUrl}" HeightRequest="160" HorizontalOptions="Fill"/>
                                </StackLayout>

                                <StackLayout Grid.Column="1">
                                    <Label Text="5 Günlük Tahmin" FontSize="12" FontAttributes="Bold" TextColor="Gray" HorizontalOptions="Center" Margin="0,0,0,5"/>
                                    <WebView Source="{Binding BesGunUrl}" HeightRequest="160" HorizontalOptions="Fill"/>
                                </StackLayout>

                            </Grid>
                        </StackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>