<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Odev3.GorevDetaySayfasi"
             Title="Görev Detayı">

    <VerticalStackLayout Spacing="15" Padding="20">

        <Label Text="Görev:" FontAttributes="Bold" TextColor="#5FBB9C"/>
        <Entry x:Name="txtBaslik" Placeholder="Yapılacak ekleme" TextColor="Black"/>

        <Label Text="Detay:" FontAttributes="Bold" TextColor="#5FBB9C"/>
        <Editor x:Name="txtDetay" Placeholder="Detay sayfası" HeightRequest="100" BackgroundColor="#F5F5F5" TextColor="Black"/>

        <HorizontalStackLayout Spacing="20">
            <VerticalStackLayout>
                <Label Text="Tarih:" FontAttributes="Bold" TextColor="#5FBB9C"/>
                <DatePicker x:Name="dpTarih" Format="dd/MM/yyyy" TextColor="5FBB9C"/>
            </VerticalStackLayout>

            <VerticalStackLayout>
                <Label Text="Saat:" FontAttributes="Bold" TextColor="#5FBB9C"/>
                <TimePicker x:Name="tpSaat" Format="HH:mm" TextColor="5FBB9C"/>
            </VerticalStackLayout>
        </HorizontalStackLayout>

        <HorizontalStackLayout Spacing="20" HorizontalOptions="Center" Margin="0,30,0,0">
            <Button Text="Tamam" Clicked="Kaydet_Clicked" BackgroundColor="#5FBB9C" TextColor="White" WidthRequest="100" CornerRadius="20"/>
            <Button Text="İptal" Clicked="Iptal_Clicked" BackgroundColor="#5FBB9C" TextColor="White" WidthRequest="100" CornerRadius="20"/>
        </HorizontalStackLayout>

    </VerticalStackLayout>
</ContentPage>